# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://mbkstodswexxvdgyunio.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Resend (outreach service only) ────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key

# ── ElevenLabs (vapi service only) ────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id
ELEVENLABS_PHONE_NUMBER_ID=your_elevenlabs_phone_number_id

# ── ElevenLabs Webhook (Supabase Edge Function secret) ────────────────────────
# Set in Supabase dashboard → Edge Functions → Secrets as ELEVENLABS_WEBHOOK_SECRET
# Webhook URL: https://mbkstodswexxvdgyunio.supabase.co/functions/v1/elevenlabs-webhook?secret=<value>
# Configure this URL in ElevenLabs dashboard → Agent → Post-call webhook

# ── Telegram (telegram service only) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID is hardcoded: 1296640696

# ── VAPI Webhook (reference only — endpoint lives in cosby-capital Next.js) ──
# The webhook URL to set in VAPI dashboard:
#   https://cosbycapital.com/api/webhooks/vapi?secret=VAPI_WEBHOOK_SECRET
# The secret is stored as an env var in Vercel, not here.

# ── Kill Switch ───────────────────────────────────────────────────────────────
# Set to "true" to enable live outreach. Any other value (or missing) = dry run.
OUTREACH_ENABLED=false
